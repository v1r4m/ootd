# 프로덕션 .env 템플릿. EC2에서 이 파일을 .env 로 복사한 뒤 값을 채운다.
#   cp .env.production.example .env
# APP_KEY 는 비워두고 deploy 전에 생성:
#   docker compose -f compose.prod.yaml run --rm app php artisan key:generate

APP_NAME=OOTD
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ootd.viram.dev
APP_TIMEZONE=Asia/Seoul

APP_LOCALE=ko
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ko_KR

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log

# 컨테이너 실행 사용자 uid/gid (deploy.sh 가 자동 감지하므로 보통 손댈 필요 없음)
APP_UID=1000
APP_GID=1000

# 공용 리버스 프록시(eta-caddy)가 붙어 있는 Docker 네트워크 이름.
# 확인: docker inspect eta-caddy-1 --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}'
PROXY_NETWORK=eta_default

# Gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image
