# 이 Caddy 는 내부에서 plain HTTP(:80)로만 동작한다.
# TLS 종료와 도메인 라우팅은 앞단의 공용 프록시(eta-caddy)가 담당한다.
:80 {
	root * /var/www/html/public
	encode gzip

	# .php 요청은 app 컨테이너의 php-fpm(9000)으로.
	# 아바타 생성이 길어질 수 있어 read_timeout 을 넉넉히 잡는다.
	php_fastcgi app:9000 {
		read_timeout 180s
	}

	file_server

	# storage 심볼릭 링크(public/storage → ../storage/app/public)로 아바타 제공
	@avatars path /storage/*
	header @avatars Cache-Control "public, max-age=86400"
}
